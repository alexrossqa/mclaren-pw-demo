{
  "name": "mclaren-css-demo",
  "version": "1.0.0",
  "description": "Playwright TypeScript CSS token and visual regression testing demo targeting mclaren.com",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:tokens": "playwright test css-tokens",
